{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "brad-esplin-temple-live",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-26",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
